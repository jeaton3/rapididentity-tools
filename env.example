# RapidIdentity Configuration

# Host URL (required)
RAPIDIDENTITY_HOST=https://rapididentity.example.com

# Authentication - Choose one of the following:

# API Key Authentication
RAPIDIDENTITY_API_KEY=your-api-key-here

# OR Basic Authentication
# RAPIDIDENTITY_USERNAME=your-username
# RAPIDIDENTITY_PASSWORD=your-password

# OR OAuth2 Authentication
# RAPIDIDENTITY_ACCESS_TOKEN=your-oauth2-token

# Authentication Type (default: api_key)
RAPIDIDENTITY_AUTH_TYPE=api_key

# Request Timeout (seconds, default: 30)
RAPIDIDENTITY_TIMEOUT=30

# Verify SSL Certificates (default: true)
RAPIDIDENTITY_VERIFY_SSL=true
